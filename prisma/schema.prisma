// Prisma schema for MedCabinet.
// Prescription stays Phase 5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Medication {
  id              Int        @id @default(autoincrement())
  brandName       String
  genericName     String?
  productType     String // "OTC" | "PRESCRIPTION"
  indications     String
  purpose         String?
  warnings        String?
  dosage          String?
  expirationDate  String?
  compartment     Int? // 1–TOTAL_COMPARTMENTS; null while pending; never scanner bay when active
  compartmentSize String? // "medium" | "thin" | "big" — auto-filled from compartment number
  status          String     @default("active") // "active" | "pending_review"
  addedAt         DateTime   @default(now())
  rawLabelText    String? // OCR dump from hardware scans (Phase 4)
  usageLogs       UsageLog[]
}

model UsageLog {
  id           Int        @id @default(autoincrement())
  medicationId Int
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  symptom      String? // what the user searched when they took it
  takenAt      DateTime   @default(now())
}
