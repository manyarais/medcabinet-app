DATABASE_URL="file:./prisma/dev.db"

# Clerk auth (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Twilio Voice dose reminders (optional).
# 1. Create a Twilio account → get Account SID + Auth Token
# 2. Buy/verify a From number (TWILIO_FROM_NUMBER), e.g. +15551234567
# 3. Put your phone as REMINDER_PHONE_NUMBER (trial accounts can only call verified numbers)
# 4. Turn ON "Server auto-call" in Settings
# 5. Auto calls need a ticker hitting POST/GET /api/reminders/dispatch:
#    Demo / presentation (points at Vercel, keep laptop open):
#      set REMINDER_DISPATCH_URL=https://YOUR-APP.vercel.app
#      npm run reminders:watch
#    Or a free external cron (cron-job.org) every 1 min → that same URL
#    (Vercel Hobby cron is once/day only — too rare for live demos)
# On Vercel you only need Twilio account keys (+ From number).
# Each household sets its own destination phone in Settings.
# Optional fallback if a household has no phone saved:
# REMINDER_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
REMINDER_PHONE_NUMBER=

# Optional: protect /api/reminders/dispatch (set the same value in the watcher / cron)
# REMINDER_DISPATCH_SECRET=
# REMINDER_DISPATCH_URL=http://localhost:3000
# REMINDER_DISPATCH_INTERVAL_MS=60000
# CRON_SECRET=  # if set, Authorization: Bearer <CRON_SECRET> is also accepted

# Optional: NL symptom extract on /symptoms (Gemini Flash). Extract-only — never recommends meds.
# Without this key, multi-word symptom search falls back to matching the raw text.
GEMINI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_SYMPTOM_MODEL=gemini-2.0-flash
