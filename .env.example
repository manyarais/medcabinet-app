DATABASE_URL="file:./prisma/dev.db"

# Twilio Voice dose reminders (optional).
# 1. Create a Twilio account → get Account SID + Auth Token
# 2. Buy/verify a From number (TWILIO_FROM_NUMBER), e.g. +15551234567
# 3. Put your phone as REMINDER_PHONE_NUMBER (trial accounts can only call verified numbers)
# 4. Restart `npm run dev`, open /calendar → Test call
# 5. For calls with the browser closed: npm run reminders:watch
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
REMINDER_PHONE_NUMBER=

# Optional: protect POST /api/reminders/dispatch (set the same value in the watcher's env)
# REMINDER_DISPATCH_SECRET=
# REMINDER_DISPATCH_URL=http://localhost:3000
# REMINDER_DISPATCH_INTERVAL_MS=60000
