// Prisma schema for MedCabinet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Medication {
  id              Int        @id @default(autoincrement())
  brandName       String
  genericName     String?
  productType     String // "OTC" | "PRESCRIPTION"
  indications     String
  purpose         String?
  warnings        String?
  dosage          String?
  expirationDate  String?
  compartment     Int? // 1–18; null while pending
  compartmentSize String? // "medium" | "thin" | "big" — auto-filled from compartment config
  outOfCabinet    Boolean    @default(false)
  status          String     @default("active") // "active" | "pending_review" | "disposed"
  addedAt         DateTime   @default(now())
  rawLabelText    String? // OCR dump from hardware scans (Phase 4)
  personName      String? // whose library this belongs to (from the PATIENT line on prescription labels); null = household
  form            String? // tablets, capsules, liquid, … (FORM line)
  prescriber      String? // prescribing doctor (Rx labels)
  pharmacy        String? // dispensing pharmacy (Rx labels)
  rxNumber        String? // prescription number (Rx labels)
  refills         String? // refill info as printed
  photoPaths      String? // JSON array of /scan-photos/... URLs from the scan
  outSince        DateTime? // when it was marked out of the cabinet (for alerts)
  disposedAt      DateTime? // when the user marked it disposed
  // --- AI layer (ai-draft). AI-written fields NEVER overwrite label text:
  // rawLabelText stays the original source; these sit alongside it.
  verificationStatus      String  @default("AI_EXTRACTED") // AI_EXTRACTED | USER_CONFIRMED | NEEDS_REVIEW
  verifiedFields          String? // JSON array of field names the user confirmed
  instructionsPlain       String? // JSON PlainLanguageResult, only generated for confirmed labels
  normalizedName          String? // e.g. "Metformin hydrochloride 500 mg oral tablet"
  rxcui                   String? // RxNorm concept id backing normalizedName
  normalizationStatus     String? // MATCHED | MULTIPLE_CANDIDATES | NO_MATCH | CONFLICTING_FIELDS | USER_REVIEW_REQUIRED
  normalizationConfidence Float?
  normalizationJson       String? // full NormalizationResult (candidates, ingredients, duplicates)
  usageLogs       UsageLog[]
  prescriptions   Prescription[]
}

/// One active-vision scan run: the planner state, per-frame analyses and the
/// cross-frame evidence accumulator. Rows double as the audit trail for what
/// the scanner did and why.
model ScanSession {
  id               String   @id @default(cuid())
  status           String   @default("CAPTURING") // CAPTURING | ANALYZING | ROTATING | COMPLETE | MAX_ROTATION_REACHED | USER_REVIEW_REQUIRED | HARDWARE_ERROR
  totalRotationDeg Int      @default(0)
  frames           String   @default("[]") // JSON FrameRecord[]
  fields           String   @default("{}") // JSON evidence accumulator (field -> candidate/confidence/frames)
  actionsLog       String   @default("[]") // JSON planned actions with reasons
  photoUrls        String   @default("[]") // JSON /scan-photos/... urls of accepted frames
  medicationId     Int?     // set once the session is completed into a Medication
  error            String?
  startedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Audit record for every AI call the app makes (spec: model version, prompt
/// version, input references, output, timestamp). Append-only.
model AiAudit {
  id            Int      @id @default(autoincrement())
  feature       String // assistant | active_scan | normalize | summary | plain_language | size_estimate
  modelVersion  String
  promptVersion String
  inputRefs     String // JSON references to the records/photos sent in
  output        String
  confidence    Float?
  createdAt     DateTime @default(now())
}

/// Generated caregiver summaries. Facts are computed deterministically first
/// (factSet) and the prose is rendered only from that payload.
model CaregiverSummary {
  id           Int       @id @default(autoincrement())
  period       String // DAILY | WEEKLY | ON_DEMAND
  headline     String
  sections     String // JSON SummarySection[] with evidence ids
  factSet      String // JSON stage-1 verified facts
  modelVersion String
  createdAt    DateTime  @default(now())
  readAt       DateTime?
}

/// Append-only log of things that happened (scans, confirmations, disposals,
/// out/return, light flashes) — powers the Activity page and alerts.
model ActivityEvent {
  id           Int      @id @default(autoincrement())
  type         String // scan_saved | scan_confirmed | scan_discarded | disposed | out | returned | flash | travel_pack | travel_return | demo_reset
  medicationId Int?
  compartment  Int?
  detail       String?
  createdAt    DateTime @default(now())
}

model UsageLog {
  id           Int        @id @default(autoincrement())
  medicationId Int?
  medication   Medication? @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  symptom      String? // what the user searched when they took it; null for scheduled Rx doses
  takenAt      DateTime   @default(now())
}

model Prescription {
  id           Int        @id @default(autoincrement())
  medicationId Int
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  dosesPerDay  Int
  pillsPerDose Int
  /// JSON array of local "HH:MM" times, length must equal dosesPerDay (e.g. ["08:00","20:00"]).
  doseTimes    String     @default("[]")
  startDate    String // YYYY-MM-DD (required — prescriptions are finite)
  endDate      String // YYYY-MM-DD (required — prescriptions are finite)
}

/// Singleton row (id = 1) for phone-call reminder preferences.
model ReminderSettings {
  id                      Int     @id @default(1)
  /// When true, /api/reminders/dispatch may place Twilio calls (app can be closed).
  serverAutoCall          Boolean @default(false)
  /// Spoken script; use {brandName} and {scheduledTime} placeholders.
  callMessageTemplate     String  @default("Hello from Pillio. This is a reminder that {brandName} is due at {scheduledTime}. Please check your Pillio calendar when you can. This is a reminder only, not medical advice. Goodbye.")
  quietHoursEnabled       Boolean @default(false)
  quietStart              String  @default("22:00") // HH:MM local
  quietEnd                String  @default("07:00") // HH:MM local (may be next morning)
  /// If true, overdue doses still trigger calls during quiet hours.
  callOverdueDuringQuiet  Boolean @default(true)
}

/// Dedupes outbound reminder calls per dose slot per day.
model ReminderCallLog {
  id             Int      @id @default(autoincrement())
  date           String // YYYY-MM-DD
  medicationId   Int
  absoluteIndex  Int
  callSid        String?
  createdAt      DateTime @default(now())

  @@unique([date, medicationId, absoluteIndex])
}
